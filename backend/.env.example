# Database
DATABASE_URL=postgresql://wifi_user:wifi_password@localhost:5432/wifi_billing

# Server
AXUM_HOST=0.0.0.0
AXUM_PORT=8080

# RADIUS
RADIUS_HOST=0.0.0.0
RADIUS_PORT=1812
RADIUS_ACCOUNTING_PORT=1813
RADIUS_SECRET=shared_secret_12345

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
# Generate with: echo -n "your_password" | argon2 "salt" -e

# M-Pesa / Daraja
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_BUSINESS_SHORT_CODE=247247
MPESA_ACCOUNT_NUMBER=0727249711
MPESA_PASSKEY=your_passkey
MPESA_API_URL=https://sandbox.safaricom.co.ke
# For production: https://api.safaricom.co.ke

# Callback URLs
MPESA_CALLBACK_URL=https://your-domain.com/api/payment/callback
RADIUS_CALLBACK_URL=https://your-domain.com/api/radius/status

# Cloudflare Tunnel (for admin remote access)
CLOUDFLARE_TUNNEL_URL=https://admin.your-tunnel.trycloudflare.com

# Logging
RUST_LOG=info,wifi_billing_backend=debug

# Security
JWT_SECRET=your_jwt_secret_key_min_32_chars
SESSION_TIMEOUT_MINS=1440

# OTP Configuration (placeholder - configure with actual SMS provider)
OTP_EXPIRY_SECS=300
OTP_RETRY_LIMIT=3
